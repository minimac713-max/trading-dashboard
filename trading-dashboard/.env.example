# Kraken API Configuration
NEXT_PUBLIC_KRAKEN_API_URL=https://api.kraken.com/0/public

# Optional: For authenticated requests (keep secret!)
# KRAKEN_API_KEY=your_api_key_here
# KRAKEN_API_SECRET=your_api_secret_here

# Dashboard Configuration
NEXT_PUBLIC_DEFAULT_PORTFOLIO_USD=10000
NEXT_PUBLIC_DEFAULT_PORTFOLIO_BTC=0.25
NEXT_PUBLIC_TRADE_SIZE=0.01
NEXT_PUBLIC_RISK_PERCENTAGE=2

# WebSocket Configuration
NEXT_PUBLIC_WS_ENABLED=true
NEXT_PUBLIC_WS_RECONNECT_INTERVAL=5000

# Email/SMS Alerts (optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASS=your_password
# ALERT_EMAIL=your_email@example.com
